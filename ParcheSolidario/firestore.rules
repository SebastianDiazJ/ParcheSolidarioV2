rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Actividades (eventos publicados) - Reglas simplificadas para debugging
    match /activities/{activityId} {
      // Todos pueden leer actividades publicadas
      allow read: if true;

      // Solo usuarios autenticados pueden crear/actualizar/borrar sus propias actividades
      allow create: if request.auth != null && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.createdBy == request.auth.uid;
    }
    // Reglas para perfiles de usuario
    match /userProfiles/{userId} {
      // Cualquier usuario autenticado puede leer todos los perfiles (necesario para panel admin)
      allow read: if request.auth != null;

      // Solo el propio usuario puede crear o modificar su perfil
      allow create, update: if request.auth != null && request.auth.uid == userId;

      // Cualquier usuario autenticado puede actualizar el estado de verificación (para panel admin)
      allow update: if request.auth != null;
    }
    
    // Reglas para otros documentos (puedes agregar más según necesites)
    match /{document=**} {
      // Por defecto, denegar acceso
      allow read, write: if false;
    }
  }
}
